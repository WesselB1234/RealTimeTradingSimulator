{
  "AppModes": {
    "TestingMode": true,
    "CachingMode": "Redis"
  },
  "ConnectionStrings": {
    "MarketSimulatorDb": "Data Source={SOURCE};Initial Catalog={DATABASE};User ID={USER_ID};Password={PASSWORD};TrustServerCertificate=True"
  },
  "RedisConnectionStrings": {
    "RedisAssetPriceInfosDb": {
      "EndPointUrl": "URL",
      "EndPointPort": 12345,
      "User": "default",
      "Password": "PASSWORD"
    }
  },
  "ApiKeyStrings": {
    "MarketApiKey": "API_KEY"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
